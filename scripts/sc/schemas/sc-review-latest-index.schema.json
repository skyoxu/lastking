{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://lastking.local/schemas/sc-review-latest-index.schema.json",
  "title": "sc-review latest-index",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "task_id",
    "run_id",
    "latest_out_dir"
  ],
  "properties": {
    "task_id": {
      "type": "string",
      "pattern": "^[0-9]+$"
    },
    "run_id": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "type": "string",
      "enum": [
        "ok",
        "fail",
        "running",
        "aborted"
      ]
    },
    "date": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
    },
    "started_at_utc": {
      "type": "string",
      "minLength": 1
    },
    "finished_at_utc": {
      "type": "string"
    },
    "run_type": {
      "type": "string",
      "enum": [
        "planned-only",
        "preflight-only",
        "llm-only",
        "deterministic-only",
        "full"
      ]
    },
    "latest_out_dir": {
      "type": "string"
    },
    "summary_path": {
      "type": "string"
    },
    "execution_context_path": {
      "type": "string"
    },
    "repair_guide_json_path": {
      "type": "string"
    },
    "repair_guide_md_path": {
      "type": "string"
    },
    "marathon_state_path": {
      "type": "string"
    },
    "run_events_path": {
      "type": "string"
    },
    "harness_capabilities_path": {
      "type": "string"
    },
    "reason": {
      "type": "string",
      "minLength": 1
    },
    "reuse_mode": {
      "type": "string",
      "enum": [
        "none",
        "full-clean-reuse",
        "deterministic-only-reuse",
        "sc-test-reuse",
        "mixed-reuse"
      ]
    },
    "deterministic_bundle": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "available",
        "reuse_mode",
        "test_summary_path",
        "acceptance_summary_path",
        "reported_out_dirs"
      ],
      "properties": {
        "available": {
          "type": "boolean"
        },
        "reuse_mode": {
          "type": "string",
          "enum": [
            "none",
            "full-clean-reuse",
            "deterministic-only-reuse",
            "sc-test-reuse",
            "mixed-reuse"
          ]
        },
        "test_summary_path": {
          "type": "string"
        },
        "acceptance_summary_path": {
          "type": "string"
        },
        "reported_out_dirs": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "diagnostics": {
      "type": "object"
    },
    "approval_request_path": {
      "type": "string"
    },
    "approval_response_path": {
      "type": "string"
    },
    "agent_review_json_path": {
      "type": "string"
    },
    "agent_review_md_path": {
      "type": "string"
    }
  }
}
