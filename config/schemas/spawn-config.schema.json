{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://lastking.local/schemas/spawn-config.schema.json",
  "title": "Lastking Spawn Timeline Input Schema",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "seed",
    "waves"
  ],
  "properties": {
    "seed": {
      "type": "integer"
    },
    "waves": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "day",
          "enemies"
        ],
        "properties": {
          "day": {
            "type": "integer",
            "minimum": 1,
            "maximum": 15
          },
          "enemies": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "enemy_id",
                "count"
              ],
              "properties": {
                "enemy_id": {
                  "type": "string",
                  "minLength": 1
                },
                "count": {
                  "type": "integer",
                  "minimum": 0
                }
              }
            }
          }
        }
      }
    }
  }
}
